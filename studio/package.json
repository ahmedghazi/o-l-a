  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@sanity/eslint-config-studio": "^6.0.0",
    "@types/react": "^19.2.14",
    "eslint": "^10.0.0",
    "prettier": "^3.8.1",
    "sanity-codegen": "^0.9.8",
